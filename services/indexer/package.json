{
  "name": "@meridian/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "meridian-indexer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "serve:supplier": "node dist/cli.js ../../infra/configs/indexer-supplier.yaml --serve",
    "serve:buyer": "node dist/cli.js ../../infra/configs/indexer-buyer.yaml --serve",
    "serve:financier-a": "node dist/cli.js ../../infra/configs/indexer-financier-a.yaml --serve",
    "serve:financier-b": "node dist/cli.js ../../infra/configs/indexer-financier-b.yaml --serve",
    "serve:regulator": "node dist/cli.js ../../infra/configs/indexer-regulator.yaml --serve",
    "serve:platform": "node dist/cli.js ../../infra/configs/indexer-platform.yaml --serve",
    "test": "node --test dist/replay-indexer.test.js dist/receivable-projector.test.js dist/financing-projector.test.js dist/bid-comparison.test.js"
  },
  "dependencies": {
    "@meridian/devnet-auth": "workspace:*",
    "@meridian/ledger-client": "workspace:*",
    "@meridian/shared-types": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
