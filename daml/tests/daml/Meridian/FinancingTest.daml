module Meridian.FinancingTest where

import Daml.Script
import DA.Time
import DA.Date
import DA.Optional
import DA.Map (toList)
import Meridian.Receivable.AssignmentConsentPolicy
import Meridian.Receivable.Types
import Meridian.Receivable.Receivable
import Meridian.Receivable.ReceivableProposal
import Meridian.Receivable.Interfaces
import Meridian.Financing.FinancingRequest
import Meridian.Financing.FinancingRoundFactory
import Meridian.Financing.Bid
import Meridian.Financing.Types
import Meridian.FinancingFixtures
import Meridian.CashFixtures
import Meridian.Settlement.Types

sampleDueDate : Date
sampleDueDate = date 2026 Dec 31

roundDeadline : Time
roundDeadline = addRelTime sampleOracleLedgerTime (days 7)

issuePostedReceivable : Party -> Party -> Script (ContractId Receivable)
issuePostedReceivable supplier buyer = do
  platformOp <- allocateParty "PlatformOp"
  proposalCid <- submit supplier do
    createCmd ReceivableProposal with
      proposalId = "FIN-001"
      supplier
      buyer
      lineItems =
        [ LineItem with description = "Services"; quantity = 1.0; unitPrice = 2000.0 ]
      faceValue = 2000.0
      currency = "USD"
      dueDate = sampleDueDate
      consentSource = InlineConsent True
  receivableCid <- submit buyer do
    exerciseCmd proposalCid CoSignAndIssue with
      jurisdiction = Some "US"
      platformOperator = platformOp
  submit supplier do exerciseCmd receivableCid PostForBid

openSampleRound :
  ContractId Receivable
  -> Party
  -> [Party]
  -> Script (ContractId FinancingRequest)
openSampleRound receivableCid supplier financiers = do
  setTime sampleOracleLedgerTime
  factoryCid <- submit supplier do createCmd FinancingRoundFactory with supplier
  submit supplier do
    exerciseCmd factoryCid OpenRound with
      receivableCid
      requestId = "ROUND-001"
      financiers
      deadline = roundDeadline
      pricingBandMin = 0.01
      pricingBandMax = 0.15
      redstoneFeedId = sofrFeedIdAscii

submitOracleBid :
  ContractId FinancingRequest
  -> Party
  -> Decimal
  -> Decimal
  -> Script (ContractId FinancingRequest, ContractId Bid)
submitOracleBid reqCid financier advance discount = do
  setTime sampleOracleLedgerTime
  submit financier do
    exerciseCmd reqCid SubmitBid with
      financier
      advanceAmount = advance
      discountRate = discount
      redstonePayload = sampleSofrPayloadHex
      redstoneTimestampMs = sampleRedstoneTimestampMs
      mode = OracleAnchored
      ledgerTime = sampleOracleLedgerTime
      viaAgent = False
      mandateCid = None

awardBidWithCash admin supplier financier reqCid bidCid advance = do
  now <- getTime
  (registryCid, rulesCid) <- bootstrapCashRegistry admin
  finHolding <- mintMusd registryCid admin financier (advance + 500.0)
  allocCid <-
    createAdvanceAllocation rulesCid admin supplier financier supplier advance now finHolding
  submit (actAs supplier <> actAs financier) do
    exerciseCmd reqCid AwardBid with
      winningBidCid = bidCid
      settlementAllocationCid = allocCid
      expectedAdvance = advance
      settlementFinancier = financier
      settlementFinality = Atomic

testFullRoundHappyPath : Script ()
testFullRoundHappyPath = script do
  admin <- allocateParty "Registry"
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"
  finB <- allocateParty "FinancierB"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA, finB]

  (reqCid1, bidA) <- submitOracleBid reqCid finA 1500.0 0.05
  (reqCid2, bidB) <- submitOracleBid reqCid1 finB 1600.0 0.04

  fundedCid <- awardBidWithCash admin supplier finB reqCid2 bidB 1600.0

  Some funded <- queryContractId supplier fundedCid
  assert (funded.state == Funded)
  assert (funded.payeeOfRecord.payee == finB)

  pure ()

testSealedBidPrivacy : Script ()
testSealedBidPrivacy = script do
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"
  finB <- allocateParty "FinancierB"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA, finB]
  (_reqCid1, _bidA) <- submitOracleBid reqCid finA 1500.0 0.05

  finBBids <- query @Bid finB
  assert (null finBBids)

  pure ()

testUninvitedFinancierNegative : Script ()
testUninvitedFinancierNegative = script do
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"
  finC <- allocateParty "FinancierC"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]

  finCRequests <- query @FinancingRequest finC
  assert (null finCRequests)

  submitMustFail finC do
    exerciseCmd reqCid SubmitBid with
      financier = finC
      advanceAmount = 1000.0
      discountRate = 0.05
      redstonePayload = sampleSofrPayloadHex
      redstoneTimestampMs = sampleRedstoneTimestampMs
      mode = OracleAnchored
      ledgerTime = sampleOracleLedgerTime
      viaAgent = False
      mandateCid = None

  pure ()

testOneBidPerFinancier : Script ()
testOneBidPerFinancier = script do
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]
  (_reqCid1, _) <- submitOracleBid reqCid finA 1500.0 0.05

  submitMustFail finA do
    exerciseCmd _reqCid1 SubmitBid with
      financier = finA
      advanceAmount = 1400.0
      discountRate = 0.04
      redstonePayload = sampleSofrPayloadHex
      redstoneTimestampMs = sampleRedstoneTimestampMs
      mode = OracleAnchored
      ledgerTime = sampleOracleLedgerTime
      viaAgent = False
      mandateCid = None

  pure ()

