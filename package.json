{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-native invoice financing & syndication exchange on Canton Network",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "codegen": "node scripts/codegen.js",
    "daml:build": "cd daml && dpm build --all",
    "daml:test": "cd daml/tests && dpm test",
    "allocate:devnet": "tsx scripts/allocate-devnet-parties.ts",
    "upload:dar:devnet": "tsx scripts/upload-dar-devnet.ts",
    "grant:devnet": "tsx scripts/grant-devnet-rights.ts",
    "fund:devnet": "tsx scripts/fund-devnet-parties.ts",
    "smoke:devnet": "tsx scripts/devnet-smoke.ts all",
    "test:phase1:devnet": "tsx scripts/phase1-devnet-integration.ts",
    "test:phase1:stack": "tsx scripts/phase1-stack-e2e.ts",
    "test:phase2:devnet": "tsx scripts/phase2-devnet-integration.ts",
    "test:phase2:stack": "tsx scripts/phase2-stack-e2e.ts",
    "test:phase3:devnet": "tsx scripts/phase3-devnet-integration.ts",
    "test:phase3:stack": "tsx scripts/phase3-stack-e2e.ts",
    "test:phase4:devnet": "tsx scripts/phase4-devnet-integration.ts",
    "test:phase4:stack": "tsx scripts/phase4-stack-e2e.ts",
    "test:phase6:devnet": "tsx scripts/phase6-devnet-integration.ts",
    "test:phase6:stack": "tsx scripts/phase6-stack-e2e.ts",
    "test:phase7:devnet": "tsx scripts/phase7-devnet-integration.ts",
    "test:phase7:stack": "tsx scripts/phase7-stack-e2e.ts",
    "bootstrap:cash:devnet": "tsx scripts/bootstrap-meridian-cash-devnet.ts",
    "redstone:fetch": "tsx scripts/fetch-redstone-data.ts --save",
    "sync:redstone-fixtures": "tsx scripts/sync-redstone-fixtures.ts",
    "debug:get-updates": "tsx scripts/debug-get-updates.ts",
    "debug:indexer-poll": "tsx scripts/debug-indexer-poll.ts",
    "portal:api": "pnpm --filter @meridian/portal-api start",
    "indexer:supplier": "pnpm --filter @meridian/indexer serve:supplier",
    "indexer:buyer": "pnpm --filter @meridian/indexer serve:buyer",
    "indexer:financier-a": "pnpm --filter @meridian/indexer serve:financier-a",
    "indexer:financier-b": "pnpm --filter @meridian/indexer serve:financier-b",
    "indexer:regulator": "pnpm --filter @meridian/indexer serve:regulator",
    "indexer:platform": "pnpm --filter @meridian/indexer serve:platform",
    "notifications": "pnpm --filter @meridian/notifications start",
    "oracle-relay": "pnpm --filter @meridian/oracle-relay start",
    "agent-runtime": "pnpm --filter @meridian/agent-runtime start",
    "registry-api": "pnpm --filter @meridian/registry-api start",
    "kyb-gateway": "pnpm --filter @meridian/kyb-gateway start",
    "party-provisioner": "pnpm --filter @meridian/party-provisioner start"
  },
  "devDependencies": {
    "@canton-network/wallet-sdk": "1.3.1",
    "@meridian/devnet-auth": "workspace:*",
    "@meridian/ledger-client": "workspace:*",
    "@meridian/oracle-feeds": "workspace:*",
    "@meridian/shared-types": "workspace:*",
    "@redstone-finance/protocol": "0.9.0",
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
