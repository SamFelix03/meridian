testPauseAndFallbackVisible : Script ()
testPauseAndFallbackVisible = script do
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]

  pausedCid <- submit supplier do exerciseCmd reqCid PauseRound
  Some paused <- queryContractId supplier pausedCid
  assert (paused.roundState == Paused)

  fallbackCid <- submit supplier do exerciseCmd pausedCid EnterStaticReferenceFallback
  Some fallback <- queryContractId finA fallbackCid
  assert (fallback.roundState == StaticReferenceFallback)

  pure ()

testBuyerNoPricingPostFund : Script ()
testBuyerNoPricingPostFund = script do
  admin <- allocateParty "Registry"
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]
  (reqCid1, bidA) <- submitOracleBid reqCid finA 1500.0 0.05
  fundedCid <- awardBidWithCash admin supplier finA reqCid1 bidA 1500.0

  buyerViews <- queryInterface @IBuyerView buyer
  assert (length buyerViews == 1)
  let [(_, Some view)] = buyerViews
  assert (view.faceValue == 2000.0)
  assert (view.payee == finA)

  pure ()

testDeadlineBoundary : Script ()
testDeadlineBoundary = script do
  admin <- allocateParty "Registry"
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]

  setTime roundDeadline
  (reqCid1, bidA) <- submitOracleBid reqCid finA 1500.0 0.05

  setTime (addRelTime roundDeadline (seconds 1))
  submitMustFail finA do
    exerciseCmd reqCid1 SubmitBid with
      financier = finA
      advanceAmount = 1400.0
      discountRate = 0.04
      redstonePayload = sampleSofrPayloadHex
      redstoneTimestampMs = sampleRedstoneTimestampMs
      mode = OracleAnchored
      ledgerTime = roundDeadline
      viaAgent = False
      mandateCid = None

  now <- getTime
  (registryCid, rulesCid) <- bootstrapCashRegistry admin
  finHolding <- mintMusd registryCid admin finA 3000.0
  allocCid <-
    createAdvanceAllocation rulesCid admin supplier finA supplier 1500.0 now finHolding

  submitMustFail supplier do
    exerciseCmd reqCid1 AwardBid with
      winningBidCid = bidA
      settlementAllocationCid = allocCid
      expectedAdvance = 1500.0
      settlementFinancier = finA
      settlementFinality = Atomic

  pure ()

testReplaceBid : Script ()
testReplaceBid = script do
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA]
  (reqCid1, _bidA) <- submitOracleBid reqCid finA 1500.0 0.05

  setTime sampleOracleLedgerTime
  (reqCid2, bidA2) <- submit finA do
    exerciseCmd reqCid1 ReplaceBid with
      financier = finA
      advanceAmount = 1450.0
      discountRate = 0.04
      redstonePayload = sampleSofrPayloadHex
      redstoneTimestampMs = sampleRedstoneTimestampMs
      mode = OracleAnchored
      ledgerTime = sampleOracleLedgerTime
      viaAgent = False
      mandateCid = None

  finABids <- query @Bid finA
  assert (length finABids == 1)
  let [(bidCid, bid)] = finABids
  assert (bidCid == bidA2)
  assert (bid.discountRate == 0.04)

  Some req <- queryContractId supplier reqCid2
  assert (length (toList req.activeBids) == 1)

  pure ()

testAwardAtomicity : Script ()
testAwardAtomicity = script do
  admin <- allocateParty "Registry"
  supplier <- allocateParty "Supplier"
  buyer <- allocateParty "Buyer"
  finA <- allocateParty "FinancierA"
  finB <- allocateParty "FinancierB"

  receivableCid <- issuePostedReceivable supplier buyer
  reqCid <- openSampleRound receivableCid supplier [finA, finB]
  (reqCid1, _) <- submitOracleBid reqCid finA 1500.0 0.05
  (reqCid2, bidB) <- submitOracleBid reqCid1 finB 1600.0 0.04

  fundedCid <- awardBidWithCash admin supplier finB reqCid2 bidB 1600.0

  finABids <- query @Bid finA
  finBBids <- query @Bid finB
  assert (null finABids)
  assert (null finBBids)

  supplierReqs <- query @FinancingRequest supplier
  assert (length supplierReqs == 1)
  let [(_, req)] = supplierReqs
  assert (req.roundState == Awarded)

  Some funded <- queryContractId supplier fundedCid
  assert (funded.state == Funded)
  assert (funded.payeeOfRecord.payee == finB)

  pure ()
